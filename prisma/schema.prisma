generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id                 String    @id @default(cuid())
  vendorId           String    @unique // Clerk User ID
  name               String
  slug               String    @unique
  description        String?
  logoUrl            String?
  primaryColor       String    @default("#4f46e6")
  announcement       String?
  islandDeliveryFee  Decimal   @default(2500)
  mainlandDeliveryFee Decimal   @default(1500)
  products           Product[]
  orders             Order[]
  visits             Int       @default(0)
  conversionClicks   Int       @default(0)
  phoneNumber        String?   // For WhatsApp Notifications
  lowStockThreshold  Int       @default(5)
  bankName           String?
  accountNumber      String?
  accountName        String?
  subaccountCode     String?   @unique
  commissionPercentage Decimal?   @default(5.0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal
  imageUrl    String?
  inStock     Boolean      @default(true)
  views       Int          @default(0) // For Advanced Analytics
  lowStockThreshold Int?       // Per-product override
  variants    Variant[]
  media       ProductMedia[]
  orderItems  OrderItem[]
  reviews     Review[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ProductMedia {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  type      String   @default("IMAGE") // IMAGE or VIDEO
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Order {
  id                String      @id @default(cuid())
  storeId           String
  store             Store       @relation(fields: [storeId], references: [id])
  customerName      String
  customerEmail     String
  customerPhone     String
  address           String
  deliveryArea      String      // MAINLAND or ISLAND
  deliveryFee       Decimal
  subtotal          Decimal
  total             Decimal
  status            String      @default("PENDING") // PENDING, PAID, SHIPPED, DELIVERED
  isDisputed        Boolean     @default(false)
  disputeReason     String?
  paystackReference String?     @unique
  
  // Dual-Confirmation Fields
  vendorConfirmedDelivery   Boolean   @default(false)
  customerConfirmedDelivery Boolean   @default(false)
  shippedAt                 DateTime?
  deliveredAt               DateTime?

  items             OrderItem[]
  reviews           Review[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Review {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerName  String
  rating        Int      @default(5)
  comment       String?
  createdAt     DateTime @default(now())
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  variantId       String?
  variant         Variant? @relation(fields: [variantId], references: [id])
  quantity        Int
  priceAtPurchase Decimal
  createdAt       DateTime @default(now())
}

model Variant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String
  sku         String?
  price       Decimal?
  stockCount  Int      @default(0)
  lowStockThreshold Int?       // Per-variant override
  orderItems  OrderItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
